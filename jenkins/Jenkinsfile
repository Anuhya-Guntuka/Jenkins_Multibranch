pipeline {
    agent { label 'maven-agent' }

    environment {
        APP_SERVER = '10.0.28.175'
        REMOTE_DIR = '/home/ubuntu/app'
        SSH_CRED = 'AppServer-SSH'
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh '/opt/maven/bin/mvn clean test'
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                    if command -v trivy >/dev/null 2>&1; then
                        trivy fs --exit-code 1 --severity HIGH,CRITICAL .
                    else
                        echo "Trivy not installed, skipping security scan"
                    fi
                '''
            }
        }

        stage('Package') {
            steps {
                sh '/opt/maven/bin/mvn clean package -DskipTests'
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }

        stage('Deploy to Application Server') {
            when {
                branch 'master'
            }
            steps {
                sshagent(credentials: [SSH_CRED]) {
                    sh """
                scp -o StrictHostKeyChecking=no target/*.jar ubuntu@${APP_SERVER}:${REMOTE_DIR}/
                ssh -o StrictHostKeyChecking=no ubuntu@${APP_SERVER} << 'EOF'
pkill -f '.jar' || true
nohup /usr/bin/java -jar ${REMOTE_DIR}/*.jar > ${REMOTE_DIR}/app.log 2>&1 &
EOF
            """
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully'
        }
        failure {
            echo 'Pipeline failed. Check console output.'
        }
    }
}
